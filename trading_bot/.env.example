# Drift Protocol Trading Bot Configuration

# Solana Configuration
# ⚠️ WARNING: Public devnet RPC is unreliable! Get a free API key from Helius (recommended)
# Free Helius key: https://www.helius.dev/ (no credit card required)
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_FREE_KEY_HERE
DRIFT_ENV=devnet

# Alternative RPC providers (all have free devnet tier):
# - QuickNode: https://your-endpoint.solana-devnet.quiknode.pro/YOUR_TOKEN/
# - Alchemy: https://solana-devnet.g.alchemy.com/v2/YOUR_API_KEY

# Wallet Configuration (REQUIRED)
# Option 1: Base58 encoded private key string
PRIVATE_KEY=your_base58_private_key_here

# Option 2: Path to Solana keypair JSON file
# PRIVATE_KEY=/path/to/your/keypair.json

# Trading Configuration
SUB_ACCOUNT_ID=0
DEBUG=true

# Risk Management (Optional - defaults will be used if not set)
# STOP_PERC=2
# MAX_POSITION_PCT=0.01
# SAFETY_MARGIN=0.95